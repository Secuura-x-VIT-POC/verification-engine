# -----------------------------
# Backend auth / audit secrets
# -----------------------------
JWT_SECRET=change-me-for-real-usage
HMAC_SECRET=change-me-for-real-usage

# -----------------------------
# Compose database defaults
# -----------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres

# -----------------------------
# Frontend API base URL
# Browser-facing URL, not the internal Docker hostname
# -----------------------------
VITE_API_BASE_URL=http://localhost:8000

# -----------------------------
# Local OCR defaults
# Native text -> PaddleOCR -> Tesseract fallback
# -----------------------------
OCR_BACKEND_MODE=AUTO
OCR_DPI=300
OCR_PREPROCESSING_ENABLED=1
PADDLEOCR_ENABLED=1
PADDLEOCR_LANGUAGE=en
TESSERACT_ENABLED=1

# -----------------------------
# Agent / NVIDIA defaults
# Optional and disabled by default
# -----------------------------
AGENT_PROVIDER=deterministic
AGENT_EXTERNAL_PROVIDER_ENABLED=0
AGENT_ORCHESTRATION_ENABLED=1

NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_REASONING_MODEL=minimaxai/minimax-m2.5
NVIDIA_PII_MODEL=nvidia/gliner-pii
NVIDIA_REASONING_ENABLED=0
NVIDIA_GLINER_PREPROCESSING_ENABLED=0

# -----------------------------
# Provider / verification defaults
# Entra stays architecturally preferred, but local mock is the default operator mode
# -----------------------------
VERIFIER_EXTERNAL_PROVIDER_ENABLED=0
VERIFIER_ENABLED_PROVIDERS=local_mock,entra_verified_id,identity_http,academic_registry_http
VERIFIER_PROVIDER_OPERATING_MODE=LOCAL_MOCK
VERIFIER_LIVE_PROVIDER_ENABLED=0
VERIFIER_EXECUTION_ENVIRONMENT_LABEL=Docker Compose local demo
VERIFIER_LOCAL_VERIFICATION_STORE_PATH=/app/backend/app/verifier_providers/fixtures/local_verification_records.json
VERIFIER_PREFERRED_PROVIDER_RAIL=entra_verified_id
VERIFIER_FALLBACK_POLICY=SUPPLEMENTARY_THEN_LOCAL_MOCK
VERIFIER_MANUAL_REVIEW_POLICY=RECOMMEND_ON_UNCERTAINTY
VERIFIER_DEMO_PROFILE_KEY=
VERIFIER_PROVIDER_TRANSITION_NOTES=Compose local demo with local OCR and local mock verification.

# -----------------------------
# Optional legacy alias envs still accepted by the current repo
# Prefer the VERIFIER_* keys above for new setup.
# -----------------------------
# PROVIDER_OPERATING_MODE=LOCAL_MOCK
# EXECUTION_ENVIRONMENT_LABEL=Docker Compose local demo
# DEMO_PROFILE_KEY=
# LOCAL_VERIFICATION_STORE_PATH=/app/backend/app/verifier_providers/fixtures/local_verification_records.json
