# -----------------------------
# Backend auth / audit secrets
# -----------------------------
JWT_SECRET=change-me-for-real-usage
HMAC_SECRET=change-me-for-real-usage

# -----------------------------
# Compose database defaults
# -----------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=edi_db
# If POSTGRES_PASSWORD or POSTGRES_DB changes after a volume already exists,
# run docker compose down -v for a fresh local dev DB or manually ALTER USER inside Postgres.

# -----------------------------
# Frontend API base URL
# Browser-facing URL, not the internal Docker hostname
# -----------------------------
VITE_API_BASE_URL=http://localhost:8000

# -----------------------------
# Mandatory production OCR defaults
# PP-ChatOCRv4-doc is the only extraction/coordinate source.
# -----------------------------
SECUURA_OCR_ENGINE=pp_chatocr_v4
SECUURA_ENABLE_ADVANCED_PADDLE_OCR=true
PP_CHAT_OCR_PIPELINE=PP-ChatOCRv4-doc
PP_CHAT_OCR_DEVICE=cpu
PP_CHAT_OCR_ENABLE_TABLE_RECOGNITION=true
PP_CHAT_OCR_ENABLE_SEAL_RECOGNITION=true
PP_CHAT_OCR_ENABLE_DOC_ORIENTATION=true
PP_CHAT_OCR_ENABLE_DOC_UNWARPING=true

# -----------------------------
# Agent / Gemini defaults
# Gemini is the active LLM orchestration path for generalized verification.
# Leave all Gemini key variables empty to use deterministic fallback behavior in local tests.
# -----------------------------
AGENT_PROVIDER=gemini
AGENT_EXTERNAL_PROVIDER_ENABLED=0
AGENT_ORCHESTRATION_ENABLED=1

GEMINI_API_KEY=
# Optional alias accepted by LangChain/Gemini tooling. Prefer GEMINI_API_KEY.
GOOGLE_API_KEY=
# Optional Gemini pool keys. Do not commit real keys. Any configured primary,
# legacy, alias, or secondary key enables live Gemini orchestration.
# Primary falls back to GEMINI_API_KEY / GOOGLE_API_KEY when empty.
GEMINI_API_KEY_PRIMARY=
# Secondary key is used by stages mapped to secondary, or after a primary slot rate limit.
# AI Studio usage can remain zero if secondary-mapped stages have no fields/claims to normalize
# or Gemini structured output is disabled. Same Google project/account may share quota;
# different accounts/projects can improve demo resilience but are not a substitute for fallback/demo mode.
GEMINI_API_KEY_SECONDARY=
# Gemini pool strategy. stage_preferred preserves per-stage routing. round_robin is
# demo/load distribution only and alternates first attempts when both slots are configured.
# Same Google project/account may still share quota; separate projects/accounts distribute load better.
# Restart the backend after changing this value in .env.
GEMINI_POOL_STRATEGY=stage_preferred
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TEMPERATURE=0
# Demo resilience fallback only; not production verification evidence.
# Multiple keys improve resilience but do not guarantee quota multiplication.
GEMINI_DEMO_FIXTURE_ENABLED=0
GEMINI_DEMO_RAW_TEXT_ENABLED=1
GEMINI_STRUCTURED_OUTPUT_ENABLED=1
GEMINI_MAX_INPUT_CHARS=12000

# -----------------------------
# Provider / verification defaults
# Entra stays architecturally preferred, but local mock is the default operator mode
# -----------------------------
VERIFIER_EXTERNAL_PROVIDER_ENABLED=0
VERIFIER_ENABLED_PROVIDERS=local_mock,entra_verified_id,identity_http,academic_registry_http
VERIFIER_PROVIDER_OPERATING_MODE=LOCAL_MOCK
VERIFIER_LIVE_PROVIDER_ENABLED=0
VERIFIER_EXECUTION_ENVIRONMENT_LABEL=Docker Compose local demo
VERIFIER_LOCAL_VERIFICATION_STORE_PATH=/app/backend/app/verifier_providers/fixtures/local_verification_records.json
VERIFIER_PREFERRED_PROVIDER_RAIL=entra_verified_id
VERIFIER_FALLBACK_POLICY=SUPPLEMENTARY_THEN_LOCAL_MOCK
VERIFIER_MANUAL_REVIEW_POLICY=RECOMMEND_ON_UNCERTAINTY
VERIFIER_DEMO_PROFILE_KEY=
VERIFIER_PROVIDER_TRANSITION_NOTES=Compose local demo with local OCR and local mock verification.

# -----------------------------
# Optional legacy alias envs still accepted by the current repo
# Prefer the VERIFIER_* keys above for new setup.
# -----------------------------
# PROVIDER_OPERATING_MODE=LOCAL_MOCK
# EXECUTION_ENVIRONMENT_LABEL=Docker Compose local demo
# DEMO_PROFILE_KEY=
# LOCAL_VERIFICATION_STORE_PATH=/app/backend/app/verifier_providers/fixtures/local_verification_records.json
